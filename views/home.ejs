<!DOCTYPE html>
<html>
<head>
    <title>Nexora</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<!-- ===== NAVBAR ===== -->
<div class="navbar">
    <div class="logo">🤖 Nexora</div>

    <div class="nav-right">
        <% if (user) { %>
            <div class="user-info">
                <img 
                    src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" 
                    class="user-avatar"
                >
                <span><%= user.username %></span>
            </div>

            <a href="/logout">
                <button class="btn-secondary">Déconnexion</button>
            </a>
        <% } else { %>
            <a href="/auth/discord">
                <button class="btn-primary">Se connecter avec Discord</button>
            </a>
        <% } %>
    </div>
</div>

<!-- ===== HERO (NON CONNECTÉ) ===== -->
<% if (!user) { %>

<div class="hero">
    <h1>Le meilleur bot<br>tout-en-un<br>pour Discord</h1>

    <p>
        Nexora est un bot Discord moderne et puissant
        pour automatiser et sécuriser votre serveur.
    </p>

    <div class="hero-buttons">
        <a href="https://discord.com/oauth2/authorize?client_id=<%= process.env.CLIENT_ID %>&permissions=8&scope=bot%20applications.commands">
            <button class="btn-primary">Ajouter à Discord</button>
        </a>

        <a href="/auth/discord">
            <button class="btn-secondary">Accéder au Dashboard</button>
        </a>
    </div>
</div>

<% } else { %>

<!-- ===== SERVEURS ===== -->
<div class="servers">
    <h1>Vos serveurs</h1>

    <div class="server-grid">
        <% guilds.forEach(guild => { %>
            <div class="server-card">

                <% if (guild.icon) { %>
                    <img 
                        src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png?size=256"
                        class="server-icon"
                    >
                <% } else { %>
                    <div class="server-icon placeholder">
                        <%= guild.name.charAt(0) %>
                    </div>
                <% } %>

                <h3><%= guild.name %></h3>

                <a href="/dashboard/<%= guild.id %>">
                    <button class="btn-primary">Gérer</button>
                </a>

            </div>
        <% }) %>
    </div>
</div>

<% } %>

</body>
</html>