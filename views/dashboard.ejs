<!DOCTYPE html>
<html>
<head>
    <title>Dashboard - <%= guild.name %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="container">

    <h1>⚙️ Dashboard : <%= guild.name %></h1>

    <!-- ================= CONFIGURATION ================= -->

    <div class="card">

        <h2>Configuration du serveur</h2>

        <form method="POST" action="/dashboard/<%= guild.id %>/save">

            <div class="form-group">
                <label>📂 ID Catégorie Tickets</label>
                <input 
                    type="text" 
                    name="ticketCategoryId"
                    value="<%= config.ticketCategoryId || '' %>"
                    placeholder="Ex: 123456789012345678"
                >
            </div>

            <div class="form-group">
                <label>📩 ID Salon Bienvenue</label>
                <input 
                    type="text" 
                    name="welcomeChannelId"
                    value="<%= config.welcomeChannelId || '' %>"
                    placeholder="Ex: 123456789012345678"
                >
            </div>

            <div class="form-group">
                <label>🎭 ID Rôle Automatique</label>
                <input 
                    type="text" 
                    name="autoRoleId"
                    value="<%= config.autoRoleId || '' %>"
                    placeholder="Ex: 123456789012345678"
                >
            </div>

            <button class="btn-primary">💾 Sauvegarder</button>

        </form>
    </div>

    <!-- ================= IA ================= -->

    <div class="card">

        <h2>Intelligence Artificielle</h2>

        <p>
            🤖 IA actuelle :
            <strong>
                <%= config.aiEnabled ? "Activée" : "Désactivée" %>
            </strong>
        </p>

        <a href="/toggle-ai/<%= guild.id %>">
            <button class="btn-secondary">
                🔄 Changer état IA
            </button>
        </a>

    </div>

    <br>
    <a href="/" class="back-link">⬅ Retour</a>

</div>

</body>
</html>